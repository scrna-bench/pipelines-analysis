        data_clusters_truth="datasets/datasets-r/.8b2abb9e/datasets-r.clusters_truth.tsv",
        methods_pca="datasets/datasets-r/.8b2abb9e/methods/pipelines-r/.34020779/datasets-r.pca.tsv",
        methods_clusters="datasets/datasets-r/.8b2abb9e/methods/pipelines-r/.34020779/datasets-r.clusters.tsv",
        methods_timings="datasets/datasets-r/.8b2abb9e/methods/pipelines-r/.34020779/datasets-r.timings.json",
        methods_clustering_info="datasets/datasets-r/.8b2abb9e/methods/pipelines-r/.34020779/datasets-r.clustering_info.json",
    output:
        "datasets/datasets-r/.8b2abb9e/methods/pipelines-r/.34020779/metrics/metrics-py/.default/datasets-r.metrics.json",
    params:
        module_dir=".modules/metrics/a97c3d8",
        entrypoint="run.py",
        output_dir=lambda wildcards, output: os.path.dirname(output[0]) or ".",
        cli_args="",
    benchmark:
        "datasets/datasets-r/.8b2abb9e/methods/pipelines-r/.34020779/metrics/metrics-py/.default/datasets-r_performance.txt"
    log:
        ".logs/datasets_datasets_r_8b2abb9e_methods_pipelines_r_34020779_metrics_metrics_py_default.log"
    container: "oras://quay.io/omnibenchmark/scrna-bench:py-rsc-0.14.1-latest-amd64"
    resources:
        cores=2
    shell:
        """
        mkdir -p {params.output_dir} $(dirname {log})
        OUTPUT_DIR=$(cd {params.output_dir} && pwd)
        INPUT_data_clusters_truth=$(cd $(dirname {input.data_clusters_truth}) && pwd)/$(basename {input.data_clusters_truth})
        INPUT_methods_pca=$(cd $(dirname {input.methods_pca}) && pwd)/$(basename {input.methods_pca})
        INPUT_methods_clusters=$(cd $(dirname {input.methods_clusters}) && pwd)/$(basename {input.methods_clusters})
        INPUT_methods_timings=$(cd $(dirname {input.methods_timings}) && pwd)/$(basename {input.methods_timings})
        INPUT_methods_clustering_info=$(cd $(dirname {input.methods_clustering_info}) && pwd)/$(basename {input.methods_clustering_info})
        LOG_FILE=$(pwd)/{log}
        exec > >(tee "$LOG_FILE") 2>&1
        echo '=== Rule: {rule} ==='
        echo 'Started:' $(date -Iseconds)
        echo '---'
        cd {params.module_dir}
        ./{params.entrypoint} \\
        --output_dir $OUTPUT_DIR \\
        --name datasets-r \\
        --data.clusters_truth $INPUT_data_clusters_truth \\
        --methods.pca $INPUT_methods_pca \\
        --methods.clusters $INPUT_methods_clusters \\
        --methods.timings $INPUT_methods_timings \\
        --methods.clustering_info $INPUT_methods_clustering_info
        """

